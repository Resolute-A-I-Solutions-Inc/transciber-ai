# ---------------------------------------------------------------------------
# transcriber-ai configuration. Copy this file to `.env` and edit as needed.
# All values are optional — the app runs out of the box with local Whisper.
# ---------------------------------------------------------------------------

# Which engine to default to: "whisper" (local, private) or "gemini" (cloud).
# The UI can still switch per-request.
TRANSCRIBE_ENGINE=whisper

# Local Whisper model size: tiny | base | small | medium | large-v3
# Larger = more accurate but slower and a bigger one-time download.
WHISPER_MODEL=small

# --- Local Whisper speed knobs ----------------------------------------------
# Implementation: faster (faster-whisper/CTranslate2, ~4x faster on CPU) | openai
WHISPER_IMPL=faster
# Device: auto (CUDA if available else CPU) | cpu | cuda
WHISPER_DEVICE=auto
# Compute type: empty => int8 on CPU / float16 on CUDA. Or: int8, int8_float16, float16, float32
WHISPER_COMPUTE=
# CTranslate2 CPU threads (0 = all physical cores)
WHISPER_CPU_THREADS=0
# Decoding beam size: 1 = greedy (fastest), 5 = default (best accuracy)
WHISPER_BEAM_SIZE=5
# Skip silence with voice-activity detection (big speedup on long, gappy audio)
WHISPER_VAD=true

# --- Google Gemini (only needed if you use the Gemini engine) --------------
# Get a key at https://aistudio.google.com/apikey . Audio is sent to Google
# (off-device) when this engine is selected — that is the privacy tradeoff
# versus local Whisper.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Uploads ----------------------------------------------------------------
# Max size (bytes) for uploaded or URL-downloaded media. Default = 2 GiB.
MAX_UPLOAD_BYTES=2147483648

# --- Persistence (PostgreSQL / Supabase via Prisma) -------------------------
# DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# --- FastAPI backend URL (transcription jobs + media serving) ---------------
FASTAPI_URL=http://localhost:8000

# --- Admin dashboard --------------------------------------------------------
# Credential to access /admin and the admin API. If EMPTY, admin is DISABLED
# (fail-closed) — the dashboard is not accessible.
ADMIN_KEY=

# Where uploaded/downloaded media is temporarily stored (auto-created).
# UPLOAD_DIR=backend/uploads
